public static void main (String[] args){
static void veterinarianMenu (ArrayList<Animal> animals, Scanner input) {

    // إنشاء طبيب
    Veterinarian vet = new Veterinarian("Ali", "0551234567", "Cow", 6);

    System.out.print("Enter Animal ID: ");
    int id = input.nextInt();

    Animal selected = null;

    // البحث على الحيوان
    for (Animal a : animals) {
        if (a.getId() == id) {
            selected = a;
            break;
        }
    }

    if (selected == null) {
        System.out.println("❌ Animal not found!");
        return;
    }

    int choice;
    do {
        System.out.println("\n===== VETERINARY MENU =====");
        System.out.println("1. Diagnose");
        System.out.println("2. Treat");
        System.out.println("3. Emergency");
        System.out.println("4. Add Appointment");
        System.out.println("5. Show History");
        System.out.println("6. Show Stats");
        System.out.println("7. Exit");

        choice = selectChoice(7, input);

        switch (choice) {

            case 1 -> {
                String result = vet.diagnose(selected);
                System.out.println("Diagnosis: " + result);
            }

            case 2 -> {
                input.nextLine(); // تنظيف
                System.out.print("Enter medicine: ");
                String med = input.nextLine();
                vet.treatAnimal(selected, med);
            }

            case 3 -> {
                vet.emergency(selected);
            }

            case 4 -> {
                input.nextLine();
                System.out.print("Enter date (yyyy-mm-dd): ");
                String date = input.nextLine();
                vet.addAppointment(date, selected);
            }

            case 5 -> {
                vet.showHistory();
            }

            case 6 -> {
                vet.showStats();
            }

        }

    } while (choice != 7);
}
